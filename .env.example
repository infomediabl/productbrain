# === Required ===
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...

# === SerpAPI (for search data & ads library) ===
SERPAPI_API_KEY=your-serpapi-api-key

# === Google Ads API (for keyword planning & campaign management) ===
# Follow these steps to get your credentials:
#
# 1. DEVELOPER TOKEN
#    - Create a Google Ads Manager Account (MCC) at https://ads.google.com
#    - Go to Tools & Settings > API Center
#    - Complete the form to get your developer token
#    - Note: You'll start with Test Account Access
#    - Apply for Basic Access for production use + keyword planning
#
# 2. OAUTH CLIENT ID & SECRET
#    - Go to https://console.cloud.google.com
#    - Create a project (or use existing)
#    - Enable the "Google Ads API"
#    - Go to APIs & Services > Credentials
#    - Create an OAuth 2.0 Client ID (Web application or Desktop type)
#    - Note the Client ID and Client Secret
#    - Configure OAuth consent screen with scope: https://www.googleapis.com/auth/adwords
#
# 3. REFRESH TOKEN
#    - Run the OAuth flow: redirect to Google's auth URL with your client_id,
#      scope=https://www.googleapis.com/auth/adwords, and access_type=offline
#    - User grants consent
#    - Exchange the authorization code for tokens
#    - Store the refresh_token (it doesn't expire unless revoked)
#
# 4. CUSTOMER ID
#    - Your 10-digit Google Ads account ID (without dashes)
#    - Found in the top-right of the Google Ads dashboard
#
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=1234567890

# Optional: If using a Manager Account (MCC) to access sub-accounts
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-mcc-customer-id

# === OpenRouter (for ad cloning image generation) ===
# Get your API key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# === Optional ===
# PORT=3100
